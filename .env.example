# Copy this file to .env and fill in real values.
# .env is ignored by git. Do not commit real API keys.

# LLM provider: DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Search provider. Choose one; Tavily is recommended for this project.
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# 163 email notification, optional for local --notify tests.
SMTP_HOST=smtp.163.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_SSL=true
SMTP_USE_TLS=false
MAIL_FROM=
MAIL_TO=

# Optional generic webhook.
DIGEST_WEBHOOK_URL=

